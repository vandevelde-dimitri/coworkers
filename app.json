{
  "expo": {
    "name": "coworkers",
    "slug": "coworkers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "coworkers",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#141E30"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dimitrivandevelde.coworkers",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Cette application nécessite l'accès à l'appareil photo pour vous permettre de prendre une photo de profil.",
        "NSPhotoLibraryUsageDescription": "Cette application nécessite l'accès à votre galerie pour vous permettre de choisir une photo de profil."
      }
    },
    "android": {
      "splash": {
        "backgroundColor": "#141E30",
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#141E30"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.dimitrivandevelde.coworkers",
      "predictiveBackGestureEnabled": false,
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'application a besoin d'accéder à vos photos pour modifier votre profil.",
          "cameraPermission": "L'application a besoin d'accéder à l'appareil photo pour prendre votre photo de profil."
        }
      ],
      "expo-system-ui",
      [
        "expo-build-properties",
        {
          "android": {
            "enableEdgeToEdge": true,
            "navigationBarColor": "#00000000",
            "statusBarColor": "transparent"
          }
        }
      ],
      "./plugins/withTransparentNavBar.js"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d1d88b17-c0af-4a2f-8e61-9667ab0c0cee"
      }
    }
  }
}
