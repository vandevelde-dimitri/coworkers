{
    "expo": {
        "name": "Coworkers",
        "slug": "coworkers",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "light",
        "newArchEnabled": true,
        "scheme": "com.coworkersapp",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#1e3a8a"
        },
        "ios": {
            "supportsTablet": true,
            "infoPlist": {
                "NSCameraUsageDescription": "Coworkers a besoin d'accéder à votre caméra pour prendre une photo de profil",
                "NSPhotoLibraryUsageDescription": "Coworkers a besoin d'accéder à vos photos pour choisir une photo de profil",
                "NSPhotoLibraryAddUsageDescription": "Coworkers a besoin de sauvegarder des photos dans votre bibliothèque"
            },
            "bundleIdentifier": "com.dimitrivandevelde.coworkers",
            "buildNumber": "1"
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#1e3a8a"
            },
            "edgeToEdgeEnabled": true,
            "predictiveBackGestureEnabled": false,
            "permissions": [
                "CAMERA",
                "READ_EXTERNAL_STORAGE",
                "WRITE_EXTERNAL_STORAGE",
                "android.permission.CAMERA"
            ],
            "package": "com.dimitrivandevelde.coworkers",
            "versionCode": 1
        },
        "web": {
            "favicon": "./assets/favicon.png"
        },
        "plugins": [
            "expo-secure-store",
            [
                "expo-camera",
                {
                    "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
                    "recordAudioAndroid": false
                }
            ]
        ],
        "extra": {
            "eas": {
                "projectId": "2c79308a-1bc8-42ed-96d8-252ef7d9214d"
            }
        },
        "owner": "protoxine"
    }
}
